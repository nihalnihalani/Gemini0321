# Google AI (Gemini + Veo + Nano Banan Pro)
GEMINI_API_KEY=

# ElevenLabs (TTS Narration)
ELEVENLABS_API_KEY=

# Vertex AI (for Lyria 2)
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Asset Storage (S3-compatible, e.g. Cloudflare R2)
# Leave blank for local /tmp asset storage during development.
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_URL=

# Telegram Bot
TELEGRAM_BOT_TOKEN=

# Redis (for BullMQ job queue + bot state)
REDIS_URL=redis://localhost:6379
ENABLE_BULLMQ=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
