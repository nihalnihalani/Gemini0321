{
  "source": "webhook_1",
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "key": "webhook://*",
        "mode": "Source",
        "name": "Web Hook",
        "include": [{ "path": "*" }],
        "parameters": {
          "endpoint": "/quality-review",
          "host": "0.0.0.0",
          "port": 5572
        },
        "sync": false,
        "type": "webhook"
      },
      "input": [],
      "ui": {}
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a senior video producer who reviews AI-generated scripts before they enter the expensive video generation pipeline. Your job is quality assurance — catch problems that would waste GPU time and produce bad videos. You review for narrative coherence, visual feasibility, pacing issues, and technical problems."
          },
          {
            "title": "Review Criteria",
            "instruction": "Evaluate the script on: 1) NARRATIVE ARC — does it have a clear beginning, middle, end? Does it build tension or interest? 2) VISUAL FEASIBILITY — are the visual descriptions concrete enough for AI video generation? Any descriptions too abstract or impossible? 3) PACING — is the duration distribution balanced? Any scene too short to register or too long to hold attention? 4) CONSISTENCY — do mood, camera style, and visual palette feel cohesive? Any jarring shifts? 5) TECHNICAL — are all required fields present and valid? Any scene_numbers out of sequence? Does total_duration match sum of scene durations?"
          },
          {
            "title": "Scoring System",
            "instruction": "Score each criterion 1-10. Calculate an overall quality_score as the weighted average: narrative (25%), visual_feasibility (30%), pacing (20%), consistency (15%), technical (10%). If overall score >= 7, the script PASSES. If < 7, it FAILS and needs revision."
          },
          {
            "title": "Improvement Suggestions",
            "instruction": "For each failing criterion (score < 7), provide specific, actionable suggestions. Not 'make it better' but 'Scene 3 visual_description is too abstract — replace metaphorical language with concrete visual elements like specific objects, actions, and lighting'. If the script passes, still provide 1-2 polish suggestions that would elevate it from good to great."
          },
          {
            "title": "Auto-Fix Capability",
            "instruction": "If the script fails, also return a 'revised_script' field with the corrected version. Apply your own suggestions — fix weak visual descriptions, adjust pacing, correct technical issues. The revised script must score >= 7 on your own criteria. If the script passes (>= 7), do NOT include revised_script."
          },
          {
            "title": "Output Format",
            "instruction": "Return JSON with: passed (boolean), quality_score (number 1-10), scores (object with narrative, visual_feasibility, pacing, consistency, technical — each 1-10), issues (array of strings — specific problems found), suggestions (array of strings — improvement recommendations), revised_script (the full corrected script object — ONLY if passed is false). The input is the raw script JSON to review."
          }
        ]
      },
      "input": [{ "lane": "text", "from": "webhook_1" }],
      "ui": {}
    },
    {
      "id": "gemini_1",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": {
          "apikey": "${ROCKETRIDE_APIKEY_GEMINI}"
        }
      },
      "input": [{ "lane": "questions", "from": "question_1" }],
      "ui": {}
    },
    {
      "id": "response_1",
      "provider": "response",
      "config": {},
      "input": [{ "lane": "answers", "from": "gemini_1" }],
      "ui": {}
    }
  ],
  "project_id": "c3d4e5f6-a7b8-9012-cdef-123456789012"
}
