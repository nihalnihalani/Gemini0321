{
  "source": "webhook_1",
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "key": "webhook://*",
        "mode": "Source",
        "name": "Web Hook",
        "include": [
          {
            "path": "*"
          }
        ],
        "parameters": {
          "endpoint": "/template-content",
          "host": "0.0.0.0",
          "port": 5568
        },
        "sync": false,
        "type": "webhook"
      },
      "input": [],
      "ui": {
        "position": {
          "x": 100,
          "y": 100
        },
        "measured": {
          "width": 220,
          "height": 60
        }
      }
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a world-class creative director at a premium design agency. You generate structured content for video templates that feels crafted, not generated. Every word must earn its place. You think in visual rhythm, brand voice, and audience psychology. The input JSON contains 'templateId', 'sourceContent', and 'sourceType'."
          },
          {
            "title": "Product Launch Template",
            "instruction": "For 'product-launch': return JSON with brandName (exact product/brand name), tagline (provocative hook — max 12 words, conversational not corporate, create desire or curiosity), productImages (empty array []), features (3-5 SHORT rhythmic phrases, 2-5 words each — these animate word-by-word so brevity is critical, use parallel structure: 'Blazing fast.', 'Dead simple.', 'Built to last.'), brandColor (hex that matches the brand's energy — bold for tech, warm for lifestyle, cool for luxury), logoUrl (empty string). Think Apple keynote meets Stripe landing page."
          },
          {
            "title": "Explainer Template",
            "instruction": "For 'explainer': return JSON with title (authoritative, clear — max 8 words), steps (3-5 objects each with title: 3-6 word action phrase, description: 1-2 sentences max 30 words explaining the concept clearly, iconUrl: empty string), conclusion (1-2 sentences — memorable takeaway, not summary), introNarration (2-3 conversational sentences that hook with a question or bold statement), summaryNarration (2-3 sentences that inspire action). Steps must follow logical cause-and-effect. Write for someone who's smart but unfamiliar."
          },
          {
            "title": "Social Promo Template",
            "instruction": "For 'social-promo': return JSON with hook (3-6 words — scroll-stopping, pattern-interrupting, uses curiosity gap or bold claim), productImage (empty string), features (3-4 ultra-short punchy phrases, 2-4 words each — benefits not features), cta (2-4 word call-to-action that creates urgency), aspectRatio ('9:16' default). Everything should feel like it belongs on a viral TikTok or Instagram Reel. No corporate speak. Bold, irreverent, direct."
          },
          {
            "title": "Brand Story Template",
            "instruction": "For 'brand-story': return JSON with companyName (exact name), mission (1-2 sentence manifesto — not a mission statement, a battle cry), teamPhotos (empty array []), milestones (3-5 objects with year: string and event: narrative sentence that reads like a story beat, not a resume bullet), vision (1-2 aspirational sentences that paint a picture of the future), logoUrl (empty string). Every word should evoke emotion. This is a story, not a corporate bio."
          },
          {
            "title": "Quality Standards",
            "instruction": "Zero filler words. No 'leveraging', 'innovative', 'cutting-edge', 'seamless', or 'synergy'. Write like a human who cares, not a marketing bot. If the source content is thin, infer and extrapolate — never return generic placeholder content. Match the energy of the source material."
          }
        ]
      },
      "input": [
        {
          "lane": "text",
          "from": "webhook_1"
        }
      ],
      "ui": {
        "position": {
          "x": 380,
          "y": 180
        },
        "measured": {
          "width": 220,
          "height": 60
        }
      }
    },
    {
      "id": "gemini_1",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": {
          "apikey": "${ROCKETRIDE_APIKEY_GEMINI}"
        }
      },
      "input": [
        {
          "lane": "questions",
          "from": "question_1"
        }
      ],
      "ui": {
