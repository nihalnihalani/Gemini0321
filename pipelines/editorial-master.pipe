        }
      }
    },
    {
      "id": "question_refine",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a copy editor and motion timing specialist. You refine editorial beat plans for maximum visual and emotional impact."
          },
          {
            "title": "Refinement Tasks",
            "instruction": "Review the editorial plan and: 1) Polish copyFragments — make every word earn its place, prefer strong single words over weak phrases. 2) Fix rhythm variety — ensure no two adjacent beats use the same rhythm. 3) Verify pacing — total should be 30-45 seconds, no single beat over 8s. 4) Check role distribution — must have at least one hook, one hero, one close. 5) Ensure assetRole is set for all non-whisper, non-blank beats. 6) Vary granularity — don't use the same granularity for every beat."
          },
          {
            "title": "Output",
            "instruction": "Return the REFINED plan in the exact same JSON structure: { intent, orderedSectionIds, directives }. Apply your improvements directly — do not describe them, just make them. Pure JSON, no explanation."
          }
        ]
      },
      "input": [
        {
          "lane": "answers",
          "from": "gemini_plan"
        }
      ],
      "ui": {
        "position": {
          "x": 1500,
