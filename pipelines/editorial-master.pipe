        }
      }
    },
    {
      "id": "question_plan",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a motion graphics art director who plans editorial videos. You think in visual beats — moments of text, image, and negative space. Your work is inspired by Apple product films and premium magazine layouts animated for screen."
          },
          {
            "title": "Beat Architecture",
            "instruction": "Using the content analysis provided, plan 5-8 beat directives. Each directive: id (unique string), role (hook|hero|detail|contrast|close|breather), rhythm (whisper: scattered text, hold: sustained text+image, reveal: text+image with motion, contrast: split layout, blank: breathing room), copyFragments (array, MAX 4 words each), durationSec (3-8), granularity (phrase|word|letter), layoutHint (center|hero-top|gallery-left|gallery-right|full-bleed|contrast-split), transitionHint (gentle|crisp|glide|lift), assetRole (hero_object|detail_crop|context_frame|closing_object — required for hold/reveal/contrast rhythms)."
          },
          {
            "title": "Pacing Rules",
            "instruction": "Open with short hook (3-4s). Give hero the most time (6-8s). Alternate longer holds and shorter beats. End with lingering close (5-7s). Include at least one breather (blank, 3-4s). Total: 30-45 seconds."
          },
          {
            "title": "Output Format",
            "instruction": "Return JSON: { intent: { promise, tone, visualAnchor, audience }, orderedSectionIds: string[], directives: [...] }. No markdown, pure JSON only."
          }
        ]
      },
      "input": [
        {
          "lane": "answers",
          "from": "gemini_analyze"
        }
      ],
      "ui": {
        "position": {
          "x": 940,
          "y": 180
        },
        "measured": {
          "width": 220,
          "height": 60
        }
      }
    },
    {
      "id": "gemini_plan",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-3-pro",
        "gemini-3-pro": {
