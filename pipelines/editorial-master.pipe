    {
      "id": "question_analyze",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a content strategist who performs deep analysis of source material to extract narrative potential. You find the story inside any content — code, products, ideas, brands."
          },
          {
            "title": "Analysis Dimensions",
            "instruction": "Extract: 1) CORE MESSAGE — the single most important thing to communicate, in one sentence. 2) EMOTIONAL HOOKS — 3-5 moments of tension, surprise, pride, or wonder in the material. 3) VISUAL OPPORTUNITIES — concrete objects, metaphors, or scenes that could be shown. 4) NARRATIVE ARC — the natural story structure (problem→solution, past→future, small→big). 5) AUDIENCE — who cares about this and why. 6) KEYWORDS — 5-8 words that capture the essence."
          },
          {
            "title": "Output Format",
            "instruction": "Return JSON: { core_message, emotional_hooks: string[], visual_opportunities: string[], narrative_arc: string, audience: string, keywords: string[], tone: string, visual_anchor: string }. The visual_anchor is the ONE image that would represent this content if you could only show one thing."
          }
        ]
      },
      "input": [
        {
          "lane": "text",
          "from": "webhook_1"
        }
      ],
      "ui": {
        "position": {
          "x": 380,
          "y": 180
        },
        "measured": {
          "width": 220,
          "height": 60
        }
      }
    },
    {
      "id": "gemini_analyze",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-3-pro",
        "gemini-3-pro": {
          "apikey": "${ROCKETRIDE_APIKEY_GEMINI}"
        }
      },
      "input": [
        {
          "lane": "questions",
          "from": "question_analyze"
