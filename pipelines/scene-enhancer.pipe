{
  "source": "webhook_1",
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "key": "webhook://*",
        "mode": "Source",
        "name": "Web Hook",
        "include": [{ "path": "*" }],
        "parameters": {
          "endpoint": "/scene-enhancer",
          "host": "0.0.0.0",
          "port": 5571
        },
        "sync": false,
        "type": "webhook"
      },
      "input": [],
      "ui": {}
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a cinematography prompt engineer who transforms basic scene descriptions into rich, photorealistic video generation prompts optimized for Google Veo. You understand camera language, lighting theory, color science, and atmospheric effects. Your prompts produce cinematic footage, not generic stock video."
          },
          {
            "title": "Enhancement Strategy",
            "instruction": "For each scene, take the visual_description and camera_direction and produce an enhanced_prompt that Veo will render beautifully. Add: specific lighting (golden hour, blue hour, overcast diffuse, neon-lit, candlelit), atmospheric effects (volumetric light rays, morning mist, rain, dust particles, lens flare), color palette (warm amber tones, cool teal shadows, desaturated, high-saturation), texture details (rough concrete, polished marble, weathered wood, frosted glass), depth cues (shallow DOF foreground blur, deep focus landscape, rack focus between subjects)."
          },
          {
            "title": "Camera Optimization",
            "instruction": "Translate generic camera directions into Veo-optimal prompts. 'slow pan' becomes 'smooth cinematic pan left to right at walking speed, gimbal-stabilized'. 'close-up' becomes 'extreme close-up with shallow depth of field, soft bokeh background, macro-like detail'. 'aerial' becomes 'drone shot ascending smoothly, revealing vast landscape below, slight forward drift'. Always specify motion speed and smoothness."
          },
          {
            "title": "Veo-Specific Tips",
            "instruction": "Veo works best with: clear subject focus (one main subject per shot), consistent motion direction, photorealistic lighting descriptions, atmospheric depth. Avoid: multiple conflicting actions, text overlays in the prompt, abstract concepts without visual grounding. Start each prompt with the most important visual element. End with mood/atmosphere. Keep prompts under 200 words but above 50 words."
          },
          {
            "title": "Output Format",
            "instruction": "The input is a JSON object with a 'scenes' array. Return a JSON object with 'enhanced_scenes' array where each element has: scene_number (matching input), enhanced_prompt (the optimized Veo prompt), negative_prompt (what to avoid: 'text, watermark, low quality, blurry, distorted, unrealistic'), aspect_ratio ('16:9' default), style_preset ('cinematic' default, or 'documentary', 'commercial', 'artistic')."
          }
        ]
      },
      "input": [{ "lane": "text", "from": "webhook_1" }],
      "ui": {}
    },
    {
      "id": "gemini_1",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": {
          "apikey": "${ROCKETRIDE_APIKEY_GEMINI}"
        }
      },
      "input": [{ "lane": "questions", "from": "question_1" }],
      "ui": {}
    },
    {
      "id": "response_1",
      "provider": "response",
      "config": {},
      "input": [{ "lane": "answers", "from": "gemini_1" }],
      "ui": {}
    }
  ],
  "project_id": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
}
