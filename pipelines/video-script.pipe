{
  "source": "webhook_1",
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "key": "webhook://*",
        "mode": "Source",
        "name": "Web Hook",
        "include": [{ "path": "*" }],
        "parameters": {
          "endpoint": "/video-script",
          "host": "0.0.0.0",
          "port": 5567
        },
        "sync": false,
        "type": "webhook"
      },
      "input": [],
      "ui": {}
    },
    {
      "id": "question_1",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are an award-winning cinematic scriptwriter and visual storytelling expert. You craft video scripts that captivate audiences through vivid imagery, precise pacing, and emotional resonance. Every scene you write is designed to translate directly into stunning AI-generated video."
          },
          {
            "title": "Scene Architecture",
            "instruction": "Each scene MUST include: scene_number (sequential from 1), title (compelling 2-5 word hook), visual_description (CRITICAL — write this as a detailed cinematographer's brief: describe setting, subjects, actions, lighting quality, color palette, time of day, atmosphere, texture, depth of field — at least 40 words), narration_text (concise voiceover, conversational not robotic, max 25 words), camera_direction (specific: 'slow dolly forward', 'aerial tracking left', 'tight close-up with shallow DOF', 'wide establishing shot', 'handheld following subject'), mood (emotional tone that drives the visual palette), duration_seconds (4, 5, 6, 7, or 8 — vary for rhythm), transition (cut for energy, fade for contemplation, dissolve for time passage, wipe for contrast)."
          },
          {
            "title": "Narrative Craft",
            "instruction": "Build a three-act structure even in short videos: Act 1 (hook + setup, 1-2 scenes), Act 2 (development + tension, 2-4 scenes), Act 3 (climax + resolution, 1-2 scenes). Vary pacing — alternate between fast cuts and lingering moments. Create visual motifs that recur. Make every scene earn its place. The opening scene must grab attention in 3 seconds. The closing scene must leave a lasting impression."
          },
          {
            "title": "Visual Direction Mastery",
            "instruction": "Vary camera angles aggressively: never use the same camera_direction twice in a row. Alternate between wide/medium/close. Use movement purposefully — static for gravity, tracking for journey, zoom for revelation, aerial for scope. Describe lighting specifically: 'golden hour rim lighting', 'cool blue ambient with warm practicals', 'high-contrast noir with single source'. Include atmospheric elements: dust motes, lens flare, volumetric fog, rain streaks, bokeh highlights."
          },
          {
            "title": "Music Direction",
            "instruction": "The music_prompt must be specific enough for AI music generation: include genre, tempo (BPM range), key instruments, emotional arc, and reference mood. Example: 'Cinematic orchestral, 90-100 BPM, strings and piano lead, building from intimate to soaring, Hans Zimmer meets Olafur Arnalds'. The music should mirror the video's emotional journey."
          },
          {
            "title": "Output Format",
            "instruction": "Return a JSON object with: title (memorable, evocative), theme (genre/style descriptor), target_audience (specific demographic), music_prompt (detailed as described above), scenes (array of scene objects as specified), total_duration_seconds (sum of all scene durations). The input contains a 'prompt' field with the video concept and a 'sceneCount' field for the number of scenes."
          }
        ]
      },
      "input": [{ "lane": "text", "from": "webhook_1" }],
      "ui": {}
    },
    {
      "id": "gemini_1",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": {
          "apikey": "${ROCKETRIDE_APIKEY_GEMINI}"
        }
      },
      "input": [{ "lane": "questions", "from": "question_1" }],
      "ui": {}
    },
    {
      "id": "response_1",
      "provider": "response",
      "config": {},
      "input": [{ "lane": "answers", "from": "gemini_1" }],
      "ui": {}
    }
  ],
  "project_id": "bc3e1fd0-d68c-4916-98ce-7129c4008b81"
}
