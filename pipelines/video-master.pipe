{
  "source": "webhook_1",
  "components": [
    {
      "id": "webhook_1",
      "provider": "webhook",
      "config": {
        "key": "webhook://*",
        "mode": "Source",
        "name": "Web Hook",
        "include": [{ "path": "*" }],
        "parameters": { "endpoint": "/video-master", "host": "0.0.0.0", "port": 5573 },
        "sync": false,
        "type": "webhook"
      },
      "input": [],
      "ui": {}
    },
    {
      "id": "question_script",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are an award-winning cinematic scriptwriter and visual storytelling expert. You craft video scripts that captivate audiences through vivid imagery, precise pacing, and emotional resonance. Every scene you write is designed to translate directly into stunning AI-generated video."
          },
          {
            "title": "Scene Architecture",
            "instruction": "Each scene MUST include: scene_number (sequential from 1), title (compelling 2-5 word hook), visual_description (CRITICAL — write as a detailed cinematographer's brief: setting, subjects, actions, lighting quality, color palette, time of day, atmosphere, texture, depth of field — at least 40 words), narration_text (concise voiceover, conversational, max 25 words), camera_direction (specific: 'slow dolly forward', 'aerial tracking left', 'tight close-up with shallow DOF'), mood (emotional tone), duration_seconds (4-8, vary for rhythm), transition (cut/fade/dissolve/wipe)."
          },
          {
            "title": "Narrative Craft",
            "instruction": "Build a three-act structure: Act 1 (hook + setup, 1-2 scenes), Act 2 (development + tension, 2-4 scenes), Act 3 (climax + resolution, 1-2 scenes). Vary pacing — alternate fast cuts and lingering moments. The opening must grab attention in 3 seconds. The closing must leave a lasting impression."
          },
          {
            "title": "Visual Direction",
            "instruction": "Never use the same camera_direction twice in a row. Alternate wide/medium/close. Describe lighting specifically: 'golden hour rim lighting', 'cool blue ambient with warm practicals'. Include atmospheric elements: dust motes, lens flare, volumetric fog, bokeh highlights."
          },
          {
            "title": "Music Direction",
            "instruction": "The music_prompt must include: genre, tempo (BPM range), key instruments, emotional arc, and reference mood. Example: 'Cinematic orchestral, 90-100 BPM, strings and piano, building from intimate to soaring'."
          },
          {
            "title": "Output Format",
            "instruction": "Return a JSON object with: title, theme, target_audience, music_prompt, scenes (array of scene objects), total_duration_seconds (sum of scene durations). The input contains a 'prompt' field and a 'sceneCount' field."
          }
        ]
      },
      "input": [{ "lane": "text", "from": "webhook_1" }],
      "ui": {}
    },
    {
      "id": "gemini_script",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": { "apikey": "${ROCKETRIDE_APIKEY_GEMINI}" }
      },
      "input": [{ "lane": "questions", "from": "question_script" }],
      "ui": {}
    },
    {
      "id": "question_review",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a senior video producer who reviews AI-generated scripts before they enter an expensive video generation pipeline. Your job is quality assurance — catch problems that would waste GPU time and produce bad videos."
          },
          {
            "title": "Review Criteria",
            "instruction": "Evaluate: 1) NARRATIVE ARC — clear beginning, middle, end? Builds interest? 2) VISUAL FEASIBILITY — descriptions concrete enough for AI video? Any too abstract? 3) PACING — duration distribution balanced? Any scene too short or too long? 4) CONSISTENCY — mood, camera style, palette cohesive? 5) TECHNICAL — all fields present? scene_numbers sequential? total_duration matches sum?"
          },
          {
            "title": "Scoring",
            "instruction": "Score each criterion 1-10. Overall quality_score = weighted average: narrative 25%, visual_feasibility 30%, pacing 20%, consistency 15%, technical 10%. Pass if >= 7."
          },
          {
            "title": "Auto-Fix and Output",
            "instruction": "ALWAYS include an 'original_script' field containing the input script unchanged. If score < 7, also include 'revised_script' with your corrected version. Return JSON: { passed, quality_score, scores: {narrative, visual_feasibility, pacing, consistency, technical}, issues: [], suggestions: [], original_script: <the input script>, revised_script: <only if failed> }."
          }
        ]
      },
      "input": [{ "lane": "answers", "from": "gemini_script" }],
      "ui": {}
    },
    {
      "id": "gemini_review",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": { "apikey": "${ROCKETRIDE_APIKEY_GEMINI}" }
      },
      "input": [{ "lane": "questions", "from": "question_review" }],
      "ui": {}
    },
    {
      "id": "question_merge",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a script selector. Your input is a quality review JSON containing 'passed', 'original_script', and optionally 'revised_script'."
          },
          {
            "title": "Logic",
            "instruction": "If 'passed' is true or no 'revised_script' exists: return the 'original_script'. If 'passed' is false and 'revised_script' exists: return the 'revised_script'. Output ONLY the pure script JSON object: { title, theme, target_audience, music_prompt, scenes: [...], total_duration_seconds }. No wrapper object, no explanation, no markdown — just the script."
          }
        ]
      },
      "input": [{ "lane": "answers", "from": "gemini_review" }],
      "ui": {}
    },
    {
      "id": "gemini_merge",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": { "apikey": "${ROCKETRIDE_APIKEY_GEMINI}" }
      },
      "input": [{ "lane": "questions", "from": "question_merge" }],
      "ui": {}
    },
    {
      "id": "question_enhance",
      "provider": "question",
      "config": {
        "profile": "default",
        "expectJson": true,
        "instructions": [
          {
            "title": "Identity",
            "instruction": "You are a cinematography prompt engineer who transforms scene descriptions into rich video generation prompts optimized for Google Veo. You understand camera language, lighting theory, color science, and atmospheric effects."
          },
          {
            "title": "Enhancement",
            "instruction": "Take the input script JSON. For each scene, enhance the visual_description into a Veo-optimized prompt: add specific lighting (golden hour, neon-lit, candlelit), atmospheric effects (volumetric rays, mist, dust, lens flare), color palette (warm amber, cool teal, desaturated), texture (rough concrete, polished marble, frosted glass), depth cues (shallow DOF, rack focus). Keep enhanced prompts 50-200 words each."
          },
          {
            "title": "Output Format",
            "instruction": "Return a JSON object with TWO fields: 'script' (the complete script with enhanced visual_descriptions replacing the originals) and 'enhanced_scenes' (array of { scene_number, enhanced_prompt, negative_prompt: 'text, watermark, low quality, blurry, distorted', style_preset: 'cinematic' }). The 'script' field must contain the full valid script object."
          }
        ]
      },
      "input": [{ "lane": "answers", "from": "gemini_merge" }],
      "ui": {}
    },
    {
      "id": "gemini_enhance",
      "provider": "llm_gemini",
      "config": {
        "profile": "gemini-2_5-flash",
        "gemini-2_5-flash": { "apikey": "${ROCKETRIDE_APIKEY_GEMINI}" }
      },
      "input": [{ "lane": "questions", "from": "question_enhance" }],
      "ui": {}
    },
    {
      "id": "response_1",
      "provider": "response",
      "config": {},
      "input": [{ "lane": "answers", "from": "gemini_enhance" }],
      "ui": {}
    }
  ],
  "project_id": "d4e5f6a7-b8c9-0123-def0-456789abcdef"
}
